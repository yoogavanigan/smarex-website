---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandCard from '../components/BrandCard.astro';
import brands from '../data/brands.json';
---

<BaseLayout>

<!-- NAV -->
<nav>
  <a href="#" class="nav-wordmark">Smarex</a>
  <ul class="nav-links">
    <li><a href="#portfolio">Portfolio</a></li>
    <li><a href="#academy">Academy</a></li>
    <li><a href="#partner">Partner</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="mailto:murali@smarex.com" class="nav-cta">Invest / Partner</a>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-bg"></div>
  <div class="hero-line"></div>
  <div class="hero-content">
    <p class="hero-eyebrow">Brand Holding Architecture · GCC & India</p>
    <h1 class="hero-title">Smar<em>ex</em></h1>
    <p class="hero-sub">A multi-vertical brand portfolio spanning Gulf and Indian markets.</p>
    <div class="hero-divider"></div>
    <p class="hero-bio">Smarex is a brand holding architecture — not a single-startup play. Each venture in the portfolio is built around a genuine market gap, a defensible name, and a clear path to revenue across GCC and India.</p>
    <div class="hero-meta">
      <div class="meta-item">
        <span class="meta-num">18+</span>
        <span class="meta-label">Active Brands</span>
      </div>
      <div class="meta-item">
        <span class="meta-num">2</span>
        <span class="meta-label">Core Markets</span>
      </div>
      <div class="meta-item">
        <span class="meta-num">6</span>
        <span class="meta-label">Sectors</span>
      </div>
    </div>
    <div class="hero-actions">
      <a href="#portfolio" class="btn-gold">Explore Portfolio</a>
      <a href="#partner" class="btn-outline">Partner With Us</a>
    </div>
  </div>
  <div class="hero-scroll">
    <span class="scroll-label">Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- MARQUEE -->
<div class="marquee-wrap">
  <div class="marquee-inner">
    <span class="marquee-item">F&amp;B</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">FinTech</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">MedTech</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">CleanTech</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">DefenceTech</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">AgriTech</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">E-Commerce</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">PropTech</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">Qatar</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">UAE</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">Tamil Nadu</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">GCC</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">India</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">F&amp;B</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">FinTech</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">MedTech</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">CleanTech</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">DefenceTech</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">AgriTech</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">E-Commerce</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">PropTech</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">Qatar</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">UAE</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">Tamil Nadu</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">GCC</span><span class="marquee-sep"> · </span>
    <span class="marquee-item">India</span><span class="marquee-sep"> · </span>
  </div>
</div>

<!-- PHILOSOPHY -->
<div class="philosophy-wrap">
  <div class="philosophy-inner">
    <div class="reveal">
      <p class="philosophy-quote">
        "An architecture that exports Indian talent, culture, and ingenuity into
        <span>Gulf and global markets</span> — built on genuine gaps, defensible
        names, and long-term conviction."
      </p>
    </div>
    <div class="philosophy-pillars reveal">
      <div class="pillar">
        <span class="pillar-num">i.</span>
        <div>
          <div class="pillar-title">Gulf-First Distribution</div>
          <p class="pillar-text">GCC positioning, trademark strategy, and Gulf NRI networks form the primary commercial moat across all portfolio brands.</p>
        </div>
      </div>
      <div class="pillar">
        <span class="pillar-num">ii.</span>
        <div>
          <div class="pillar-title">India Root Architecture</div>
          <p class="pillar-text">Theni and Kongu region roots supply authentic brand narratives, supply chain access, and manufacturing advantage.</p>
        </div>
      </div>
      <div class="pillar">
        <span class="pillar-num">iii.</span>
        <div>
          <div class="pillar-title">Build · Sell · Hold</div>
          <p class="pillar-text">Each brand is classified under a disciplined capital-allocation model. Build with conviction. Sell with structure. Hold without dilution.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- PORTFOLIO -->
<div class="portfolio-wrap" id="portfolio">
  <div class="portfolio-header reveal">
    <div class="portfolio-header-left">
      <p class="section-tag">Smarex Portfolio</p>
      <h2 class="section-heading">The <em>Brands</em></h2>
      <div class="section-rule"></div>
    </div>
    <div class="portfolio-legend">
      <div class="legend-item"><div class="legend-dot dot-build"></div>Build Priority</div>
      <div class="legend-item"><div class="legend-dot dot-sell"></div>Sell Candidate</div>
      <div class="legend-item"><div class="legend-dot dot-dev"></div>Development</div>
    </div>
  </div>
  <div class="portfolio-grid">
    {brands.map(brand => <BrandCard {...brand} />)}
  </div>
</div>

<!-- ACADEMY -->
<div class="academy-wrap" id="academy">
  <div class="academy-inner">
    <div class="reveal">
      <p class="section-tag">Smarex Academy</p>
      <h2 class="section-heading">Research &amp; <em>Programmes</em></h2>
      <div class="section-rule"></div>
      <p class="academy-intro">A knowledge and community engine — building research capability, security culture, and entrepreneurial talent across GCC and India.</p>
    </div>
    <div class="academy-grid">

      <div class="academy-card reveal">
        <div class="academy-card-track">Research</div>
        <div class="academy-card-num">01</div>
        <div class="academy-card-title">Industry &amp; Market Research</div>
        <p class="academy-card-desc">Structured research events and published intelligence reports covering GCC and Indian market verticals — designed to inform investors, founders, and strategic partners inside and outside the Smarex portfolio.</p>
        <ul class="academy-card-list">
          <li>Sector intelligence reports</li>
          <li>GCC &amp; India market summits</li>
          <li>Investor-grade research outputs</li>
          <li>Annual Smarex Market Outlook</li>
        </ul>
      </div>

      <div class="academy-card reveal">
        <div class="academy-card-track">Security</div>
        <div class="academy-card-num">02</div>
        <div class="academy-card-title">Bug Bounty Services</div>
        <p class="academy-card-desc">Managed bug bounty and responsible disclosure programmes as a service — offered to GCC startups, enterprises, and government entities seeking structured security research without building an internal team.</p>
        <ul class="academy-card-list">
          <li>Managed disclosure programmes</li>
          <li>Researcher reward infrastructure</li>
          <li>Vulnerability triage &amp; reporting</li>
          <li>Security posture benchmarking</li>
        </ul>
      </div>

      <div class="academy-card reveal">
        <div class="academy-card-track">Community</div>
        <div class="academy-card-num">03</div>
        <div class="academy-card-title">Hackathons</div>
        <p class="academy-card-desc">High-energy build events designed to groom young talent from GCC campuses and Tamil Nadu colleges — connecting problem statements from the Smarex portfolio directly to the next generation of builders and entrepreneurs.</p>
        <ul class="academy-card-list">
          <li>48-hour build challenges</li>
          <li>GCC &amp; Tamil Nadu campus editions</li>
          <li>Mentorship by portfolio founders</li>
          <li>Incubation pathways for top teams</li>
        </ul>
      </div>

    </div>
  </div>
</div>

<!-- PARTNERSHIP -->
<div class="partner-wrap" id="partner">
  <div class="partner-inner">
    <div class="reveal">
      <p class="section-tag">Opportunities</p>
      <h2 class="section-heading">Partner with <em>Smarex</em></h2>
      <div class="section-rule"></div>
    </div>
    <div class="partner-grid">
      <div class="partner-card reveal">
        <div class="partner-card-num">01</div>
        <div class="partner-card-title">Invest in a Brand</div>
        <p class="partner-card-desc">Take a stake in one or more portfolio brands at any stage — from early concept through to market-ready ventures with traction.</p>
        <ul class="partner-card-list">
          <li>Equity participation</li>
          <li>Revenue share structures</li>
          <li>Brand acquisition</li>
        </ul>
      </div>
      <div class="partner-card reveal">
        <div class="partner-card-num">02</div>
        <div class="partner-card-title">Join as Co-Founder</div>
        <p class="partner-card-desc">Several brands are actively seeking co-founders with domain expertise in trading, F&amp;B, logistics, healthcare, or GCC market operations.</p>
        <ul class="partner-card-list">
          <li>Equbri — FinTech co-founder</li>
          <li>Probfit — Trading platform</li>
          <li>Yeluck — Ground CEO, Bodi</li>
        </ul>
      </div>
      <div class="partner-card reveal">
        <div class="partner-card-num">03</div>
        <div class="partner-card-title">Strategic Partnership</div>
        <p class="partner-card-desc">Distribution, licensing, or strategic alliances across GCC and Indian markets — particularly for brands with clear regional advantage.</p>
        <ul class="partner-card-list">
          <li>GCC distribution rights</li>
          <li>India manufacturing tie-ups</li>
          <li>Trademark &amp; IP licensing</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<!-- ABOUT -->
<div id="about">
  <div class="about-wrap">
    <div class="about-inner">
      <div class="reveal">
        <p class="section-tag">About Smarex</p>
        <h2 class="section-heading">The <em>Engine</em></h2>
        <div class="section-rule"></div>
      </div>
      <div class="reveal">
        <p class="about-statement">Smarex was built by an entrepreneur and software consultant based in Doha, Qatar, with roots in Theni, Tamil Nadu — where a multi-generational family legacy in food and hospitality provided both inspiration and grounding.</p>
        <p class="about-statement">The portfolio is funded through consulting income and structured under a Build–Sell–Hold model. Each brand earns its classification through genuine market research, naming strategy, and a clear monetisation path.</p>
        <div class="about-box" style="margin-top:2.5rem">
          <p class="about-box-label">Operating Philosophy</p>
          <p class="about-box-text">Build with conviction. Sell with structure. Develop without dilution. Capital flows to momentum — and time flows to what is urgent.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- CTA -->
<div class="cta-wrap" id="contact">
  <div class="cta-inner reveal">
    <p class="cta-eyebrow">Investors · Co-Founders · Strategic Partners</p>
    <h2 class="cta-heading">Let's build <em>together.</em></h2>
    <p class="cta-body">Whether you are an investor looking for a GCC-India portfolio play, a co-founder with domain expertise, or a strategic partner — there is a place for the right people in Smarex.</p>
    <div class="cta-buttons">
      <a href="mailto:murali@smarex.com" class="btn-gold">Get in Touch</a>
      <a href="#portfolio" class="btn-outline">Browse Portfolio</a>
    </div>
  </div>
  <div class="cta-links reveal">
    <a href="mailto:murali@smarex.com" class="cta-link-card">
      <div>
        <p class="cta-link-label">Email</p>
        <p class="cta-link-value">murali@smarex.com</p>
      </div>
      <span class="cta-arrow">→</span>
    </a>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <span class="footer-mark">Smarex</span>
  <span class="footer-copy">© 2026 · Doha, Qatar · GCC & India · All rights reserved</span>
</footer>

<script>
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('in');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

</BaseLayout>
